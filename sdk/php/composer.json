{
    "name": "muninndb/client",
    "description": "Official PHP SDK for MuninnDB — the cognitive memory database",
    "type": "library",
    "license": "MIT",
    "keywords": ["muninndb", "memory", "cognitive", "database", "ai", "sdk"],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MuninnDB\\": "src/"
        },
        "classmap": [
            "src/Types/Types.php",
            "src/Exceptions/Exceptions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MuninnDB\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "minimum-stability": "stable"
}
